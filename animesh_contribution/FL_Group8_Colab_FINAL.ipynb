    "# ── Choose how many experiments to run ─────────────────────────────────\n",
    "# QUICK_MODE = True  → 2 runs (baseline_NQ vs proposed_NQ)  ~10 min\n",
    "# QUICK_MODE = False → 4 runs (all configurations)          ~20 min\n",
    "QUICK_MODE = False   # ← set True for a faster test run\n",
    "\n",
    "if QUICK_MODE:\n",
    "    EXPERIMENTS = [\n",
    "        ('baseline', False),   # baseline_NQ\n",
    "        ('proposed', False),   # proposed_NQ\n",
    "    ]\n",
    "    print('Quick mode: 2 experiments (~10 min). Set QUICK_MODE=False for all 4.\\n')\n",
    "else:\n",
    "    EXPERIMENTS = [\n",
    "        ('baseline', False),   # baseline_NQ\n",
    "        ('baseline', True),    # baseline_Q\n",
    "        ('proposed', False),   # proposed_NQ\n",
    "        ('proposed', True),    # proposed_Q\n",
    "    ]\n",
    "    print('Full mode: 4 experiments (~20 min).\\n')\n",
    "\n",
    "ALL_RESULTS: Dict[str, dict] = {}\n",
    "t0 = time.time()\n",
    "for _mode, _quant in EXPERIMENTS:\n",
    "    _key = f\"{_mode}_{'Q' if _quant else 'NQ'}\"\n",
    "    _ts  = time.time()\n",
    "    ALL_RESULTS[_key] = run_experiment(_mode, _quant)\n",
    "    print(f'  ⏱  {_key} done in {(time.time()-_ts)/60:.1f} min')\n",
    "print(f'\\n✅ All done in {(time.time()-t0)/60:.1f} min total')\n"
   ]
  },
