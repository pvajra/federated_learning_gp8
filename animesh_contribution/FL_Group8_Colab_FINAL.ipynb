   "source": [
    "class Net(nn.Module):\n",
    "    \"\"\"\n",
    "    CNN for MNIST. Proposal Table II: CNN architecture.\n",
    "    Conv(1→32)+Pool → Conv(32→64)+Pool → FC(3136→256)+Dropout → FC(256→10)\n",
    "    \"\"\"\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.conv1   = nn.Conv2d(1, 32, kernel_size=3, padding=1)\n",
    "        self.conv2   = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n",
    "        self.pool    = nn.MaxPool2d(2, 2)\n",
    "        self.dropout = nn.Dropout(p=0.25)\n",
    "        self.fc1     = nn.Linear(64 * 7 * 7, 256)\n",
    "        self.fc2     = nn.Linear(256, 10)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = self.pool(F.relu(self.conv1(x)))   # 32x14x14\n",
    "        x = self.pool(F.relu(self.conv2(x)))   # 64x7x7\n",
    "        x = torch.flatten(x, 1)               # 3136\n",
    "        x = self.dropout(F.relu(self.fc1(x)))\n",
    "        return self.fc2(x)\n",
    "\n",
    "_d = Net()\n",
    "_o = _d(torch.zeros(4, 1, 28, 28))\n",
    "assert _o.shape == (4, 10)\n",
    "print(f'✅ Net: output {list(_o.shape)} | params: {sum(p.numel() for p in _d.parameters()):,}')\n",
    "del _d, _o"
   ]
  },
