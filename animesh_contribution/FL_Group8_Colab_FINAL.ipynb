    "## Cell 7 — Flower Client\n",
    "Simulated IoT device. Implements proposal Eq. 2–4:\n",
    "- `E_compute = CPU_cycles × α` (α=1e-6 J/cycle)\n",
    "- `E_comm = data_transmitted × β` (β=5e-7 J/byte)\n",
    "- `E_total = E_compute + E_comm`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "code-7",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "code-7",
    "outputId": "042a9846-feab-453e-f4ac-f9b397172f43"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ FlowerClient | α=1e-06 J/cycle | β=5e-07 J/byte\n"
     ]
    }
   ],
   "source": [
    "ALPHA = 1e-6   # J/cycle\n",
    "BETA  = 5e-7   # J/byte\n",
    "_J_TO_KWH = 1.0 / 3_600_000.0\n",
    "_CL_DEV = torch.device('cpu')\n",
    "\n",
    "class FlowerClient(fl.client.NumPyClient):\n",
    "    \"\"\"\n",
    "    Simulated IoT device.\n",
    "    profile keys: battery, cpu_factor, compression, dropout\n",
    "    carbon_intensity: gCO2eq/kWh for this device's grid zone.\n",
    "    \"\"\"\n",
    "    def __init__(self, trainloader, profile, use_quantization=False, carbon_intensity=250.0):\n",
    "        self.model   = Net().to(_CL_DEV)\n",
    "        self.loader  = trainloader\n",
    "        self.profile = profile\n",
    "        self.use_q   = use_quantization\n",
    "        self.carbon  = carbon_intensity\n",
    "        self._crit   = nn.CrossEntropyLoss()\n",
    "\n",
    "    def get_parameters(self, config):\n",
    "        return [v.cpu().numpy() for v in self.model.state_dict().values()]\n",
    "\n",
    "    def set_parameters(self, parameters):\n",
    "        self.model.load_state_dict(\n",
    "            {k: torch.tensor(v, device=_CL_DEV)\n",
    "             for k, v in zip(self.model.state_dict().keys(), parameters)},\n",
    "            strict=True)\n",
    "\n",
    "    def fit(self, parameters, config):\n",
    "        dp = self.profile.get('dropout', 0.10)\n",
    "        if random.random() < dp:\n",
    "            return self.get_parameters({}), 0, self._zero_metrics()\n",
    "\n",
    "        self.set_parameters(parameters)\n",
    "        cf   = self.profile.get('cpu_factor',  1.0)\n",
    "        comp = self.profile.get('compression', 1.0)\n",
    "\n",
    "        opt = optim.SGD(self.model.parameters(), lr=0.01, momentum=0.9, weight_decay=1e-4)\n",
    "        self.model.train()\n",
    "        steps = 0; max_b = max(1, int(len(self.loader) * cf))\n",
    "        for i, (x, y) in enumerate(self.loader):\n",
    "            if i >= max_b: break\n",
    "            x, y = x.to(_CL_DEV), y.to(_CL_DEV)\n",
    "            opt.zero_grad()\n",
    "            self._crit(self.model(x), y).backward()\n",
    "            opt.step(); steps += 1\n",
    "\n",
    "        # Eq. 3 & 4\n",
    "        comp_e  = steps * cf * 1_000 * ALPHA\n",
    "        bpp     = 2 if self.use_q else 4\n",
    "        n_p     = sum(p.numel() for p in self.model.parameters())\n",
    "        comm_e  = n_p * bpp * comp * BETA\n",
    "        total_e = comp_e + comm_e\n",
    "        carbon  = total_e * _J_TO_KWH * self.carbon\n",
    "\n",
    "        params = self.get_parameters({})\n",
    "        if self.use_q: params = [p.astype(np.float16) for p in params]\n",
    "        return params, len(self.loader.dataset), {\n",
    "            'compute_energy': comp_e, 'communication_energy': comm_e,\n",
    "            'total_energy': total_e, 'carbon_emissions': carbon,\n",
    "            'battery': self.profile.get('battery', 0.5),\n",
    "            'cpu': self.profile.get('cpu_factor', 1.0),\n",
    "            'compression': self.profile.get('compression', 1.0),\n",
    "            'data_size': len(self.loader.dataset),\n",
    "            'dropout_risk': dp, 'quantized': int(self.use_q), 'steps': steps,\n",
    "        }\n",
    "\n",
    "    def evaluate(self, parameters, config):\n",
    "        self.set_parameters(parameters); self.model.eval()\n",
    "        loss = correct = total = 0\n",
    "        with torch.no_grad():\n",
    "            for x, y in self.loader:\n",
    "                x, y = x.to(_CL_DEV), y.to(_CL_DEV)\n",
    "                out = self.model(x)\n",
    "                loss += self._crit(out, y).item()\n",
    "                correct += (out.argmax(1) == y).sum().item()\n",
    "                total   += y.size(0)\n",
    "        return float(loss), total, {'accuracy': correct / max(total, 1)}\n",
    "\n",
    "    def _zero_metrics(self):\n",
    "        return {'compute_energy': 0.0, 'communication_energy': 0.0,\n",
    "                'total_energy': 0.0, 'carbon_emissions': 0.0,\n",
    "                'battery': self.profile.get('battery', 0.5),\n",
    "                'cpu': self.profile.get('cpu_factor', 1.0),\n",
    "                'compression': self.profile.get('compression', 1.0),\n",
    "                'data_size': 0, 'dropout_risk': self.profile.get('dropout', 0.10),\n",
    "                'quantized': int(self.use_q), 'steps': 0}\n",
    "\n",
    "print(f'✅ FlowerClient | α={ALPHA:.0e} J/cycle | β={BETA:.0e} J/byte')"
   ]
  },
