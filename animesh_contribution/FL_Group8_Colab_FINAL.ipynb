   "source": [
    "## Cell 8 — Simulation Engine\n",
    "**⚙️ Edit `NUM_ROUNDS` here:**\n",
    "- `NUM_ROUNDS = 30` → ~15–20 min (quick test)\n",
    "- `NUM_ROUNDS = 100` → ~45–60 min (full proposal Table II run)\n",
    "\n",
    "### Key fix: CID-to-profile mapping\n",
    "Flower assigns large UUID-style integers as client IDs in newer versions.\n",
    "We map each CID to a profile by **sorting all available CIDs and using their sorted position index**,\n",
    "which is deterministic and consistent across rounds."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "code-8",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "code-8",
    "outputId": "5ea6cac9-a3c3-4099-ffb6-af4d8df4742d"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loading MNIST...\n",
      "✅ 50 clients | 1,200 samples each\n",
      "   Device mix: {'sensor': 22, 'mobile': 12, 'edge': 16}\n",
      "\n",
      "✅ Simulation engine ready.\n",
      "   Config: 50 clients | 30 rounds | 10/round\n"
     ]
    }
   ],
   "source": [
    "# ── ⚙️  CONFIGURATION ──────────────────────────────────────────────────────\n",
    "NUM_CLIENTS       = 50\n",
    "NUM_ROUNDS        = 30 ",
    "CLIENTS_PER_ROUND = 10\n",
    "SEED              = 42\n",
    "W1, W2, W3, W4   = 0.30, 0.30, 0.20, 0.20  # Eq. 1 weights\n",
    "_MAX_E            = 0.015  # Joules — reward normalisation cap\n",
    "# ── end configuration ──────────────────────────────────────────────────────\n",
    "\n",
    "random.seed(SEED); np.random.seed(SEED); torch.manual_seed(SEED)\n",
    "\n",
    "print('Loading MNIST...')\n",
    "TRAINLOADERS, TESTLOADER = load_datasets(NUM_CLIENTS, seed=SEED)\n",
    "print(f'✅ {NUM_CLIENTS} clients | {len(TRAINLOADERS[0].dataset):,} samples each')\n",
    "\n",
    "# ── Device profiles (proposal Table II compression ratios) ─────────────────\n",
    "# sensor=25%, mobile=50%, edge=100%\n",
    "_PROFILES = {\n",
    "    'sensor': {'battery': 0.35, 'cpu_factor': 0.50, 'compression': 0.25, 'dropout': 0.30},\n",
    "    'mobile': {'battery': 0.65, 'cpu_factor': 0.80, 'compression': 0.50, 'dropout': 0.15},\n",
    "    'edge':   {'battery': 1.00, 'cpu_factor': 1.20, 'compression': 1.00, 'dropout': 0.05},\n",
    "}\n",
    "_prng = random.Random(SEED)\n",
    "# List of profiles indexed 0..NUM_CLIENTS-1 (position-based, not CID-based)\n",
    "PROFILE_LIST = [\n",
    "    dict(_PROFILES[_prng.choice(list(_PROFILES.keys()))])\n",
    "    for _ in range(NUM_CLIENTS)\n",
    "]\n",
    "\n",
    "_cnt = {t: sum(1 for p in PROFILE_LIST if p['cpu_factor'] == v['cpu_factor'])\n",
    "        for t, v in _PROFILES.items()}\n",
    "print(f'   Device mix: {_cnt}')\n",
    "\n",
    "\n",
    "# ── Cache: populated on first configure_fit, stable across all rounds ──────\n",
    "_ALL_CIDS_SORTED: List[str] = []   # set once when first round starts\n",
    "\n",
    "\n",
    "# ── Global test-set evaluation ─────────────────────────────────────────────\n",
    "def evaluate_global_model(parameters) -> float:\n",
    "    model = Net()\n",
    "    model.load_state_dict(\n",
    "        {k: torch.tensor(v) for k, v in zip(model.state_dict().keys(), parameters)},\n",
    "        strict=True)\n",
    "    model.eval()\n",
    "    correct = total = 0\n",
    "    with torch.no_grad():\n",
    "        for x, y in TESTLOADER:\n",
    "            correct += (model(x).argmax(1) == y).sum().item()\n",
    "            total   += y.size(0)\n",
    "    return correct / max(total, 1)\n",
    "\n",
    "\n",
    "# ── Proposal Eq. 1 — participation score ───────────────────────────────────\n",
    "def participation_score(profile: dict) -> float:\n",
    "    return (W1 * profile.get('battery', 0.5)\n",
    "          + W2 * (profile.get('cpu_factor', 1.0) / 1.2)\n",
    "          + W3 * 1.0\n",
    "          + W4 * (1.0 - profile.get('dropout', 0.15)))\n",
    "\n",
    "\n",
    "# ── Experiment runner ───────────────────────────────────────────────────────\n",
    "def run_experiment(mode: str, use_quantization: bool) -> dict:\n",
    "    \"\"\"\n",
    "    Run one FL experiment.\n",
    "    mode: 'baseline' | 'proposed'\n",
    "    Returns per-round metric lists.\n",
    "    \"\"\"\n",
    "    global _ALL_CIDS_SORTED\n",
    "    _ALL_CIDS_SORTED = []   # reset so we re-capture CIDs for each experiment\n",
    "\n",
    "    tag = 'Q' if use_quantization else 'NQ'\n",
    "    run_name = f'{mode}_{tag}'\n",
    "    print(f'\\n{chr(9472)*58}')\n",
    "    print(f'  {run_name}  |  {NUM_ROUNDS} rounds  |  {CLIENTS_PER_ROUND}/round')\n",
    "    print(f'{chr(9472)*58}')\n",
    "\n",
    "    reset_carbon_cache()\n",
    "\n",
    "    acc_log=[]; comp_log=[]; comm_log=[]; total_log=[]; carbon_log=[]\n",
    "    _prev_acc = [0.0]\n",
    "    dqn = DQNAgent(seed=SEED) if mode == 'proposed' else None\n",
    "\n",
    "    def evaluate_fn(server_round, parameters, config):\n",
    "        acc = evaluate_global_model(parameters)\n",
    "        acc_log.append(acc)\n",
    "        print(f'  Round {server_round:03d}/{NUM_ROUNDS}  |  accuracy = {acc:.4f}', flush=True)\n",
    "        _prev_acc[0] = acc\n",
    "        return 0.0, {'accuracy': acc}\n",
    "\n",
    "    def client_fn(cid: str) -> FlowerClient:\n",
    "        # We cannot use int(cid) because Flower may assign UUID-style CIDs.\n",
    "        # Instead, use the sorted-rank index (populated on first configure_fit).\n",
    "        # On the very first call we fall back to a hash-based deterministic index.\n",
    "        if _ALL_CIDS_SORTED:\n",
    "            # Prefer rank if already known\n",
    "            try:\n",
    "                idx = _ALL_CIDS_SORTED.index(cid) % NUM_CLIENTS\n",
    "            except ValueError:\n",
    "                idx = abs(hash(cid)) % NUM_CLIENTS\n",
    "        else:\n",
    "            idx = abs(hash(cid)) % NUM_CLIENTS\n",
    "\n",
    "        profile = PROFILE_LIST[idx]\n",
    "        carbon  = get_carbon_intensity_by_index(idx, 1, NUM_CLIENTS)\n",
    "        return FlowerClient(TRAINLOADERS[idx], profile, use_quantization, carbon)\n",
    "\n",
    "    class EnergyAwareStrategy(fl.server.strategy.FedAvg):\n",
    "\n",
    "        def configure_fit(self, server_round, parameters, client_manager):\n",
    "            global _ALL_CIDS_SORTED\n",
    "            avail = list(client_manager.all().values())\n",
    "\n",
    "            # ── Populate sorted CID list once (first round) ────────────────\n",
    "            if not _ALL_CIDS_SORTED:\n",
    "                _ALL_CIDS_SORTED = sorted([c.cid for c in avail])\n",
    "\n",
    "            # Helper: get stable 0-based index for any CID\n",
    "            def _idx(cid):\n",
    "                try:    return _ALL_CIDS_SORTED.index(cid)\n",
    "                except: return abs(hash(cid)) % NUM_CLIENTS\n",
    "\n",
    "            # ── BASELINE: random selection ─────────────────────────────────\n",
    "            if mode == 'baseline':\n",
    "                chosen = random.sample(avail, min(CLIENTS_PER_ROUND, len(avail)))\n",
    "                return [(c, fl.common.FitIns(parameters, {})) for c in chosen]\n",
    "\n",
    "            # ── PROPOSED: DQN carbon-aware selection ───────────────────────\n",
    "            states = {}\n",
    "            for c in avail:\n",
    "                i = _idx(c.cid)\n",
    "                p = PROFILE_LIST[i]\n",
    "                states[c.cid] = [\n",
    "                    get_normalised_carbon_by_index(i, server_round, NUM_CLIENTS),\n",
    "                    p.get('battery',    0.5),\n",
    "                    p.get('cpu_factor', 1.0) / 1.2,\n",
    "                    p.get('dropout',    0.10),\n",
    "                    server_round / NUM_ROUNDS,\n",
    "                ]\n",
    "\n",
    "            sel_cids = dqn.select_clients(states, CLIENTS_PER_ROUND)\n",
    "            pm       = {c.cid: c for c in avail}\n",
    "            chosen   = [pm[cid] for cid in sel_cids if cid in pm]\n",
    "\n",
    "            # Safety: ensure exactly CLIENTS_PER_ROUND\n",
    "            if len(chosen) < CLIENTS_PER_ROUND:\n",
    "                extras = [c for c in avail if c.cid not in set(sel_cids)]\n",
    "                chosen += random.sample(extras, min(CLIENTS_PER_ROUND - len(chosen), len(extras)))\n",
    "\n",
    "            return [\n",
    "                (c, fl.common.FitIns(\n",
    "                    parameters,\n",
    "                    {'carbon_intensity': float(\n",
    "                        get_carbon_intensity_by_index(_idx(c.cid), server_round, NUM_CLIENTS))}\n",
    "                ))\n",
    "                for c in chosen\n",
    "            ]\n",
    "\n",
    "        def aggregate_fit(self, server_round, results, failures):\n",
    "            agg_p, agg_m = super().aggregate_fit(server_round, results, failures)\n",
    "\n",
    "            def _idx(cid):\n",
    "                try:    return _ALL_CIDS_SORTED.index(cid)\n",
    "                except: return abs(hash(cid)) % NUM_CLIENTS\n",
    "\n",
    "            rc = rm = rt = rcarbon = 0.0\n",
    "            for proxy, res in results:\n",
    "                m = res.metrics\n",
    "                rc      += m.get('compute_energy',       0.0)\n",
    "                rm      += m.get('communication_energy', 0.0)\n",
    "                rt      += m.get('total_energy',         0.0)\n",
    "                rcarbon += m.get('carbon_emissions',     0.0)\n",
    "\n",
    "                if mode == 'proposed':\n",
    "                    i  = _idx(proxy.cid)\n",
    "                    pf = PROFILE_LIST[i]\n",
    "                    nc = get_normalised_carbon_by_index(i, server_round, NUM_CLIENTS)\n",
    "                    state = [nc, pf.get('battery',0.5), pf.get('cpu_factor',1.0)/1.2,\n",
    "                             pf.get('dropout',0.10), server_round / NUM_ROUNDS]\n",
    "                    nstate= [get_normalised_carbon_by_index(i, server_round+1, NUM_CLIENTS),\n",
    "                             pf.get('battery',0.5), pf.get('cpu_factor',1.0)/1.2,\n",
    "                             pf.get('dropout',0.10), (server_round+1)/NUM_ROUNDS]\n",
    "                    prev   = acc_log[-2] if len(acc_log) >= 2 else 0.0\n",
    "                    reward = DQNAgent.compute_reward(\n",
    "                        min(m.get('total_energy',0.0)/_MAX_E, 1.0), nc, _prev_acc[0]-prev)\n",
    "                    dqn.store(state, reward, nstate, done=(server_round == NUM_ROUNDS))\n",
    "\n",
    "            if mode == 'proposed': dqn.learn(); dqn.decay_epsilon()\n",
    "\n",
    "            comp_log.append(rc); comm_log.append(rm)\n",
    "            total_log.append(rt); carbon_log.append(rcarbon)\n",
    "            return agg_p, agg_m\n",
    "\n",
    "    fl.simulation.start_simulation(\n",
    "        client_fn = client_fn,\n",
    "        num_clients = NUM_CLIENTS,\n",
    "        config = fl.server.ServerConfig(num_rounds=NUM_ROUNDS),\n",
    "        strategy = EnergyAwareStrategy(\n",
    "            fraction_fit          = CLIENTS_PER_ROUND / NUM_CLIENTS,\n",
    "            min_fit_clients       = CLIENTS_PER_ROUND,\n",
    "            min_available_clients = NUM_CLIENTS,\n",
    "            evaluate_fn           = evaluate_fn,\n",
    "            fraction_evaluate     = 0.0,\n",
    "            min_evaluate_clients  = 0,\n",
    "        ),\n",
    "        client_resources = {'num_cpus': 1, 'num_gpus': 0.0},\n",
    "        ray_init_args    = {\n",
    "            'num_cpus': 2, 'num_gpus': 0,\n",
    "            'include_dashboard': False,\n",
    "            'ignore_reinit_error': True,\n",
    "        },\n",
    "    )\n",
    "\n",
    "    ml = min(len(acc_log), len(comp_log), len(comm_log), len(total_log), len(carbon_log))\n",
    "    result = {'name': run_name,\n",
    "              'accuracy':             acc_log[:ml],\n",
    "              'compute_energy':       comp_log[:ml],\n",
    "              'communication_energy': comm_log[:ml],\n",
    "              'total_energy':         total_log[:ml],\n",
    "              'carbon_emissions':     carbon_log[:ml]}\n",
    "\n",
    "    df = pd.DataFrame({'round': range(1, ml+1), **{k: v for k,v in result.items() if k!='name'}})\n",
    "    p  = OUTPUT_DIR / f'{run_name}_results.csv'\n",
    "    df.to_csv(p, index=False)\n",
    "    print(f'  ✓ Saved {p.name}')\n",
    "    return result\n",
    "\n",
    "print('\\n✅ Simulation engine ready.')\n",
    "print(f'   Config: {NUM_CLIENTS} clients | {NUM_ROUNDS} rounds | {CLIENTS_PER_ROUND}/round')"
   ]
  },
