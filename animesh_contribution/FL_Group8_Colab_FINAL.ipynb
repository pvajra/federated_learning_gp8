   "source": [
    "COLOURS = {'baseline_NQ':'#1565C0','baseline_Q':'#64B5F6',\n",
    "           'proposed_NQ':'#B71C1C','proposed_Q':'#EF9A9A'}\n",
    "LINES   = {'baseline_NQ':'-','baseline_Q':'--','proposed_NQ':'-','proposed_Q':'--'}\n",
    "\n",
    "def smooth(v, w=3): return pd.Series(v).rolling(w, min_periods=1).mean().tolist()\n",
    "\n",
    "# Summary table\n",
    "print(f\"\\n{'='*72}\")\n",
    "print(f\"  {'Run':<14}  {'Final Acc':>9}  {'Peak Acc':>8}  {'Total E (J)':>11}  {'CO2 (gCO2eq)':>12}\")\n",
    "print(f\"  {'-'*14}  {'-'*9}  {'-'*8}  {'-'*11}  {'-'*12}\")\n",
    "for k, r in ALL_RESULTS.items():\n",
    "    if not r['accuracy']: continue\n",
    "    print(f\"  {k:<14}  {r['accuracy'][-1]:>9.4f}  {max(r['accuracy']):>8.4f}  \"\n",
    "          f\"{sum(r['total_energy']):>11.5f}  {sum(r['carbon_emissions']):>12.4f}\")\n",
    "print(f\"{'='*72}\")\n",
    "\n",
    "if 'baseline_NQ' in ALL_RESULTS and 'proposed_NQ' in ALL_RESULTS:\n",
    "    be = sum(ALL_RESULTS['baseline_NQ']['total_energy'])\n",
    "    pe = sum(ALL_RESULTS['proposed_NQ']['total_energy'])\n",
    "    bc = sum(ALL_RESULTS['baseline_NQ']['carbon_emissions'])\n",
    "    pc = sum(ALL_RESULTS['proposed_NQ']['carbon_emissions'])\n",
    "    if be > 0: print(f'  Energy reduction (proposed vs baseline): {(be-pe)/be*100:.1f}%')\n",
    "    if bc > 0: print(f'  Carbon reduction (proposed vs baseline): {(bc-pc)/bc*100:.1f}%')\n",
    "\n",
    "# Plot 1: Accuracy | Total Energy | Carbon\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 5))\n",
    "fig.suptitle(f'FL — Baseline vs Proposed (DQN Carbon-Aware)\\n'\n",
    "             f'MNIST | {NUM_CLIENTS} clients | {NUM_ROUNDS} rounds | {CLIENTS_PER_ROUND}/round',\n",
    "             fontsize=12, fontweight='bold')\n",
    "for ax, (m, title, yl) in zip(axes, [\n",
    "    ('accuracy',         'Global Test Accuracy',       'Accuracy'),\n",
    "    ('total_energy',     'Total Energy per Round',     'Energy (J)'),\n",
    "    ('carbon_emissions', 'Carbon Emissions per Round', 'gCO2eq'),\n",
    "]):\n",
    "    for k, r in ALL_RESULTS.items():\n",
    "        if r[m]:\n",
    "            ax.plot(range(1, len(r[m])+1), smooth(r[m]),\n",
    "                    label=k, color=COLOURS[k], linestyle=LINES[k], linewidth=2)\n",
    "    ax.set_title(title, fontsize=11, fontweight='bold')\n",
    "    ax.set_xlabel('Round'); ax.set_ylabel(yl)\n",
    "    ax.legend(fontsize=8); ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "p1 = OUTPUT_DIR / 'experiment_results.png'\n",
    "plt.savefig(p1, dpi=150, bbox_inches='tight'); plt.close()\n",
    "display(IPImage(str(p1))); print(f'  ✓ {p1.name}')\n",
    "\n",
    "# Plot 2: Energy breakdown\n",
    "fig2, ax2 = plt.subplots(1, 2, figsize=(12, 5))\n",
    "fig2.suptitle('Energy Breakdown: Compute vs Communication', fontsize=12, fontweight='bold')\n",
    "for ax, (m, yl) in zip(ax2, [\n",
    "    ('compute_energy',       'Compute Energy (J)'),\n",
    "    ('communication_energy', 'Communication Energy (J)'),\n",
    "]):\n",
    "    for k, r in ALL_RESULTS.items():\n",
    "        if r[m]:\n",
    "            ax.plot(range(1, len(r[m])+1), smooth(r[m]),\n",
    "                    label=k, color=COLOURS[k], linestyle=LINES[k], linewidth=2)\n",
    "    ax.set_title(yl, fontsize=11, fontweight='bold')\n",
    "    ax.set_xlabel('Round'); ax.set_ylabel(yl)\n",
    "    ax.legend(fontsize=8); ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "p2 = OUTPUT_DIR / 'energy_breakdown.png'\n",
    "plt.savefig(p2, dpi=150, bbox_inches='tight'); plt.close()\n",
    "display(IPImage(str(p2))); print(f'  ✓ {p2.name}')\n",
    "\n",
    "# Summary CSV\n",
    "rows = []\n",
    "for k, r in ALL_RESULTS.items():\n",
    "    if not r['accuracy']: continue\n",
    "    rows.append({'run': k, 'rounds': len(r['accuracy']),\n",
    "                 'final_accuracy':  r['accuracy'][-1],\n",
    "                 'peak_accuracy':   max(r['accuracy']),\n",
    "                 'total_compute_E': sum(r['compute_energy']),\n",
    "                 'total_comm_E':    sum(r['communication_energy']),\n",
    "                 'total_energy':    sum(r['total_energy']),\n",
    "                 'total_carbon':    sum(r['carbon_emissions'])})\n",
    "sdf = pd.DataFrame(rows)\n",
    "sp  = OUTPUT_DIR / 'comparison_summary.csv'\n",
    "sdf.to_csv(sp, index=False)\n",
    "print(f'  ✓ {sp.name}')\n",
    "display(sdf.round(5))"
   ]
